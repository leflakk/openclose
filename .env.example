# OpenClose — messaging credentials (deliver_message tool + Jobs notifications)
#
# Copy this file to ~/.config/openclose/.env (XDG_CONFIG_HOME on Linux;
# ~/Library/Application Support/openclose on macOS; %APPDATA%\openclose
# on Windows) and fill in the values for the platforms you want to use.
#
# Real environment variables always take precedence over values in the
# .env file (override=False), so CI/production config is safe.
#
# The channel aliases defined below serve two purposes:
#   1. The agent's `deliver_message` tool selects from them by name.
#   2. Jobs (cron-scheduled skill chains) pick one as the target for
#      their post-run notification. Define a channel once, address it
#      from both places.


# ═══ Bot credentials ═════════════════════════════════════════════════
# Telegram: create a bot via @BotFather, paste the HTTP API token:
OPENCLOSE_TELEGRAM_BOT_TOKEN=

# Discord: create an application at
# https://discord.com/developers/applications, turn it into a bot, paste
# the bot token below.  The bot must be invited to the target server
# and have "Send Messages" permission in each destination channel.
OPENCLOSE_DISCORD_BOT_TOKEN=


# ═══ Channel aliases ═════════════════════════════════════════════════
# Format: OPENCLOSE_CHANNEL_<ALIAS>=<platform>:<target_id>
# <platform> is "telegram" or "discord".
# <target_id>:
#   Telegram — a chat_id (positive for private chats, negative for
#              groups/supergroups; supergroups often start with -100).
#              Get yours by messaging @userinfobot or forwarding a
#              message to @RawDataBot.
#   Discord  — a channel_id (18+ digit snowflake).  Enable Developer
#              Mode in Discord, right-click the channel, "Copy ID".
#
# Aliases are case-insensitive.  The agent passes one or more alias
# names to deliver_message(channels=[...], message="...").
#
# Examples (uncomment and edit):
#OPENCLOSE_CHANNEL_ME=telegram:123456789
#OPENCLOSE_CHANNEL_OPS=telegram:-1001234567890
#OPENCLOSE_CHANNEL_TEAMCHAT=discord:987654321098765432


# ═══ Telegram outbound allowlist (optional safety rail) ══════════════
# If set, deliver_message refuses to POST to any Telegram chat_id that
# is not in this comma-separated list — even if a matching channel
# alias exists.  Useful as a second line of defence against leaked
# tokens or misconfigured aliases.
#
# Leave unset (or empty) to disable the gate.  Does not apply to
# Discord.
#
#OPENCLOSE_TELEGRAM_ALLOWED_USERS=123456789,-1001234567890


# ═══ Per-chunk delivery pacing (optional) ════════════════════════════
# Milliseconds to wait between chunks when a long message is split
# across multiple API calls.  Default 350ms — safe under both
# Telegram's ~1 msg/sec per-chat limit and Discord's 5-in-5s per-
# channel limit.
#
#OPENCLOSE_DELIVER_MESSAGE_CHUNK_DELAY_MS=350
